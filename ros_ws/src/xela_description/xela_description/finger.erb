

<%
require 'erb'
require 'matrix'
require_relative 'finger'
require_relative 'list_to_string'

p4 = LinkP4.new('rf')
p3 = LinkP3.new('rf')
p2 = LinkP2.new('rf')
fingertop = LinkFingertop.new('rf')

rf_links = [p4, p3, p2, fingertop]
rf_joints = [JointP4P3.new('rf', 0.0), JointP3P2.new('rf', 0.0), JointP2Fingertop.new('rf', 0.0)]

finger = Finger.new('rf', rf_links, rf_joints)




%>

<?xml version="1.0" ?>
<robot name="xela_finger_generated">
<% for link in finger.links do %>
  <link name="<%= link.link_name %>">
    <inertial>
      <origin xyz="<%= list_to_string(link.inertial[:origin][:xyz]) %>" 
      rpy="<%= list_to_string(link.inertial[:origin][:rpy]) %>"/>
      <mass value="<%= link.inertial[:mass] %>"/>
      <inertia ixx="<%= link.inertial[:inertia][:ixx] %>" ixy="<%= link.inertial[:inertia][:ixy] %>" ixz="<%= link.inertial[:inertia][:ixz] %>" iyy="<%= link.inertial[:inertia][:iyy] %>" iyz="<%= link.inertial[:inertia][:iyz] %>" izz="<%= link.inertial[:inertia][:izz] %>"/>
    </inertial>
    <visual>
      <origin xyz="<%= list_to_string(link.visual[:origin][:xyz]) %>" rpy="<%= list_to_string(link.visual[:origin][:rpy]) %>"/>
      <geometry>
        <mesh filename="<%= link.visual[:geometry][:mesh][:filename] %>"/>
      </geometry>
      <material name="<%= link.visual[:material][:name] %>">
        <color rgba="<%= list_to_string(link.visual[:material][:color][:rgba]) %>"/>
      </material>
    </visual>
    <collision>
      <origin xyz="<%= list_to_string(link.collision[:origin][:xyz]) %>" rpy="<%= list_to_string(link.collision[:origin][:rpy]) %>"/>
      <geometry>
        <mesh filename="<%= link.collision[:geometry][:mesh][:filename] %>"/>
      </geometry>
    </collision>
  </link>
<% end %>


<% for joint in finger.joints do %>
  <joint name="<%= joint.joint_name %>" type="<%= joint.joint_type %>">
    <origin xyz="<%= list_to_string(joint.origin[:xyz]) %>" rpy="<%= list_to_string(joint.origin[:rpy]) %>"/>
    <parent link="<%= joint.parent_link_name %>"/>
    <child link="<%= joint.child_link_name %>"/>
    <axis xyz="<%= list_to_string(joint.axis) %>"/>
    <limit effort="<%= joint.limit[:effort] %>" velocity="<%= joint.limit[:velocity] %>" lower="<%= joint.limit[:lower] %>" upper="<%= joint.limit[:upper] %>"/>
  </joint>
<% end %>


<link name="base"/>
<joint name="base" type="fixed">
  <origin xyz="0 0 0" rpy="1.57 0 0"/>
  <parent link="base"/>
  <child link="<%= finger.links[0].link_name %>"/>
</joint>
</robot>